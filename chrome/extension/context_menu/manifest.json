{
  "manifest_version": 3,
  "name": "Block Right Click",
  "version": "1.0",

  "permissions": [
    "tabs",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "chrome_url_overrides": {
    "newtab": "index.html"
  }
}
